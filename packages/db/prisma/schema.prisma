generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EventType {
  HOME_PARTY
  CLUB_NIGHT
  CONCERT
}

enum AlcoholPolicy {
  NONE
  PROVIDED
  BYOB
}

enum AgeRestriction {
  ALL_AGES
  AGE_18
  AGE_21
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REMOVED
  WAITLISTED
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum AccountMode {
  ATTENDEE
  HOST
}

enum NotificationType {
  RSVP_CONFIRMED
  INVITE_RECEIVED
  EVENT_REMINDER
  CELEBRITY_NEARBY
  EVENT_UPDATED
  MESSAGE
  INTEREST_MATCH
  PARTY_BLAST
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum VenueType {
  BAR
  NIGHTCLUB
  CONCERT_HALL
  ROOFTOP_BAR
  PUB
  LOUNGE
}

enum GroupType {
  GENRE
  VENUE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String           @id @default(cuid())
  firebaseUid       String           @unique
  email             String           @unique
  username          String           @unique
  displayName       String
  gender            Gender?
  bio               String?
  photoUrl          String?
  ageVerified       Boolean          @default(false)
  alcoholFriendly   Boolean          @default(false)
  interests         String[]
  showAlcoholEvents Boolean          @default(false)
  subscriptionTier  SubscriptionTier @default(FREE)
  accountMode      AccountMode      @default(ATTENDEE)
  stripeCustomerId  String?
  fcmToken          String?
  lastKnownLat      Float?
  lastKnownLng      Float?
  isBanned          Boolean          @default(false)
  isAdmin           Boolean          @default(false)
  referralCode      String?          @unique
  referralBalance   Float            @default(0)
  referredBy        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  hostedEvents  Event[]             @relation("HostedEvents")
  guestEntries  EventGuest[]
  tickets       Ticket[]
  sightings     CelebritySighting[]
  sightingVotes SightingVote[]
  notifications Notification[]
  subscription  Subscription?
  claimedVenues Venue[]             @relation("ClaimedVenues")
  sentMessages  Message[]           @relation("SentMessages")
  sentDMs       DirectMessage[]     @relation("SentDMs")
  conversations ConversationParticipant[]

  following        Follow[]      @relation("UserFollowing")
  followers        Follow[]      @relation("UserFollowers")
  checkIns         CheckIn[]
  posts            Post[]
  postLikes        PostLike[]
  reviews          EventReview[]
  createdSquads    Squad[]       @relation("CreatedSquads")
  squadMemberships SquadMember[]
  savedEvents      SavedEvent[]
  groupMemberships  GroupMembership[]
  sentGroupMessages GroupMessage[] @relation("SentGroupMessages")
}

model Event {
  id                    String         @id @default(cuid())
  hostId                String
  host                  User           @relation("HostedEvents", fields: [hostId], references: [id])
  name                  String
  type                  EventType
  description           String
  startsAt              DateTime
  endsAt                DateTime?
  lat                   Float
  lng                   Float
  address               String
  neighbourhood         String
  showNeighbourhoodOnly Boolean        @default(false)
  capacity              Int
  price                 Float          @default(0)
  ticketQuantity        Int            @default(0)
  ticketsRemaining      Int            @default(0)
  alcoholPolicy         AlcoholPolicy  @default(NONE)
  ageRestriction        AgeRestriction @default(ALL_AGES)
  dressCode             String?
  whatToBring           String[]
  houseRules            String?
  vibeTags              String[]
  isInviteOnly          Boolean        @default(false)
  inviteToken           String?        @unique
  isPublished           Boolean        @default(false)
  isCancelled           Boolean        @default(false)
  isFeatured            Boolean        @default(false)
  coverImageUrl         String?
  accentColor           String?
  stripeProductId       String?
  stripePriceId         String?
  hostRating            Float?
  eventbriteId          String?        @unique
  eventbriteUrl         String?
  socialSourceUrl       String?
  venueId               String?
  venue                 Venue?         @relation(fields: [venueId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  guests   EventGuest[]
  tickets  Ticket[]
  messages Message[]

  checkIns CheckIn[]
  posts    Post[]
  reviews  EventReview[]
  savedBy  SavedEvent[]
}

model EventGuest {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RSVPStatus @default(PENDING)
  invitedAt DateTime   @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Ticket {
  id              String    @id @default(cuid())
  eventId         String
  userId          String
  event           Event     @relation(fields: [eventId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  qrCode          String    @unique @default(cuid())
  stripePaymentId String?
  stripeSessionId String?
  pricePaid       Float
  platformFee     Float
  scannedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([eventId])
  @@index([userId])
}

model CelebritySighting {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  celebrity   String
  lat         Float
  lng         Float
  description String?
  photoUrl    String?
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  isVerified  Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  votes SightingVote[]

  @@index([expiresAt])
  @@index([lat, lng])
}

model SightingVote {
  id         String            @id @default(cuid())
  sightingId String
  userId     String
  sighting   CelebritySighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  isUpvote   Boolean
  createdAt  DateTime          @default(now())

  @@unique([sightingId, userId])
}

model Subscription {
  id                   String           @id @default(cuid())
  userId               String           @unique
  user                 User             @relation(fields: [userId], references: [id])
  tier                 SubscriptionTier
  stripeSubscriptionId String?          @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

// ─── Venues ───────────────────────────────────────────────────────────────────

model Venue {
  id            String    @id @default(cuid())
  googlePlaceId String?   @unique
  name          String
  address       String
  city          String
  lat           Float
  lng           Float
  type          VenueType
  phone         String?
  website       String?
  photoUrl      String?
  rating        Float?
  openingHours  Json?
  vibeTags      String[]
  isClaimed     Boolean   @default(false)
  claimedById   String?
  claimedBy     User?     @relation("ClaimedVenues", fields: [claimedById], references: [id])
  events        Event[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  checkIns CheckIn[]
  posts    Post[]

  @@index([lat, lng])
  @@index([city])
}

// ─── Direct Messages ──────────────────────────────────────────────────────────

model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  lastMessage  String?
  lastAt       DateTime?
  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentDMs", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  eventId   String
  senderId  String
  text      String   @db.Text
  createdAt DateTime @default(now())

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id])

  @@index([eventId, createdAt])
}

// ─── Social ───────────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model CheckIn {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venueId    String?
  venue      Venue?    @relation(fields: [venueId], references: [id], onDelete: SetNull)
  crowdLevel String?   // QUIET | BUSY | RAMMED
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([venueId])
}

model Post {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  venueId    String?
  venue      Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  imageUrl   String?
  text       String?    @db.Text
  isStory    Boolean    @default(false)
  expiresAt  DateTime?
  likesCount Int        @default(0)
  createdAt  DateTime   @default(now())

  likes PostLike[]

  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model EventReview {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rating      Int
  vibeRating  Int?
  musicRating Int?
  crowdRating Int?
  text        String?  @db.Text
  createdAt   DateTime @default(now())

  @@unique([userId, eventId])
  @@index([eventId])
}

model Squad {
  id        String        @id @default(cuid())
  name      String
  emoji     String        @default("🎉")
  createdBy String
  creator   User          @relation("CreatedSquads", fields: [createdBy], references: [id])
  members   SquadMember[]
  createdAt DateTime      @default(now())
}

model SquadMember {
  id        String   @id @default(cuid())
  squadId   String
  userId    String
  role      String   @default("MEMBER") // ADMIN | MEMBER
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([squadId, userId])
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
}

// ─── Group Chats ──────────────────────────────────────────────────────────────

model GroupChat {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  description  String?
  type         GroupType
  emoji        String    @default("🎉")
  coverColor   String    @default("#a855f7")
  isPrivate    Boolean   @default(false)
  password     String?
  isPaid       Boolean   @default(false)
  priceMonthly Float?
  stripePriceId String?
  createdById  String?
  memberCount  Int       @default(0)
  lastMessage  String?
  lastAt       DateTime?
  createdAt    DateTime  @default(now())

  memberships GroupMembership[]
  messages    GroupMessage[]
  subscriptions GroupSubscription[]
}

model GroupSubscription {
  id                   String    @id @default(cuid())
  groupId              String
  userId               String
  group                GroupChat  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

// ─── Referrals ───────────────────────────────────────────────────────────────

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  referredId   String    @unique
  code         String
  earnedAmount Float     @default(0)
  isPaidOut    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([referrerId])
  @@index([code])
}

model GroupMembership {
  id                   String    @id @default(cuid())
  groupId              String
  userId               String
  notificationsEnabled Boolean   @default(true)
  joinedAt             DateTime  @default(now())
  group                GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model GroupMessage {
  id        String    @id @default(cuid())
  groupId   String
  senderId  String
  text      String    @db.Text
  createdAt DateTime  @default(now())
  group     GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User      @relation("SentGroupMessages", fields: [senderId], references: [id])

  @@index([groupId, createdAt])
}
