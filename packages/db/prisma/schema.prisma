generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EventType {
  HOME_PARTY
  CLUB_NIGHT
  CONCERT
  PUB_NIGHT
  BEACH_PARTY
  YACHT_PARTY
}

enum AlcoholPolicy {
  NONE
  PROVIDED
  BYOB
}

enum AgeRestriction {
  ALL_AGES
  AGE_18
  AGE_21
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REMOVED
  WAITLISTED
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum AccountMode {
  ATTENDEE
  HOST
}

enum NotificationType {
  RSVP_CONFIRMED
  INVITE_RECEIVED
  EVENT_REMINDER
  CELEBRITY_NEARBY
  EVENT_UPDATED
  MESSAGE
  INTEREST_MATCH
  PARTY_BLAST
  FOLLOW
  PROFILE_VIEW
  NUDGE
  GO_OUT_REQUEST
  GO_OUT_ACCEPTED
  GROUP_INVITE_RECEIVED
  COMMENT_MENTION
  POST_COMMENT
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum VenueType {
  BAR
  NIGHTCLUB
  CONCERT_HALL
  ROOFTOP_BAR
  PUB
  LOUNGE
}

enum GroupType {
  GENRE
  VENUE
  FESTIVAL
  TRIP
}

enum AppRole {
  USER
  MODERATOR
  ADMIN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String           @id @default(cuid())
  firebaseUid       String           @unique
  email             String           @unique
  username          String           @unique
  displayName       String
  gender            Gender?
  bio               String?
  photoUrl          String?
  ageVerified       Boolean          @default(false)
  alcoholFriendly   Boolean          @default(false)
  interests         String[]
  showAlcoholEvents Boolean          @default(true)
  phoneNumber    String?   @unique
  phoneVerified  Boolean   @default(false)
  profileBg      String?   // hex colour or gradient string
  themeColor     String?   // hex accent colour
  themeName      String?   // e.g. "neon", "gold", "sunset"
  profileBgImage String?   // URL to uploaded background image
  currency       String    @default("GBP") // ISO 4217 currency code
  socialScore    Int       @default(0)
  subscriptionTier  SubscriptionTier @default(FREE)
  accountMode      AccountMode      @default(ATTENDEE)
  stripeCustomerId  String?
  // Stripe Connect Express — for hosts that receive ticket revenue payouts.
  // `chargesEnabled` + `payoutsEnabled` + `detailsSubmitted` are cached from
  // Stripe's `account.updated` webhook so request handlers don't have to make
  // an extra API call per checkout.
  stripeConnectAccountId       String?
  stripeConnectChargesEnabled  Boolean  @default(false)
  stripeConnectPayoutsEnabled  Boolean  @default(false)
  stripeConnectDetailsSubmitted Boolean @default(false)
  fcmToken          String?
  lastKnownLat      Float?
  lastKnownLng      Float?
  lastLat           Float?
  lastLng           Float?
  lastSeenAt        DateTime?
  isBanned          Boolean          @default(false)
  isAdmin           Boolean          @default(false)
  appRole           AppRole          @default(USER)
  contentStrikes    Int              @default(0)
  referralCode      String?          @unique
  referralBalance   Float            @default(0)
  referredBy        String?
  e2ePublicKey      String?          @db.Text
  // Settings / preferences
  notifPrefs        Json?            // { RSVP_CONFIRMED: bool, FOLLOW: bool, ... }
  showInNearby      Boolean          @default(true)
  showProfileViews  Boolean          @default(true)
  allowGoOutFromStrangers Boolean    @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  hostedEvents        Event[]             @relation("HostedEvents")
  guestEntries        EventGuest[]
  eventModeratorRoles EventModerator[]    @relation("EventModeratorUser")
  eventModerationsAdded EventModerator[]  @relation("EventModeratorAddedBy")
  tickets       Ticket[]
  sightings     CelebritySighting[]
  sightingVotes SightingVote[]
  notifications Notification[]
  subscription  Subscription?
  claimedVenues Venue[]             @relation("ClaimedVenues")
  sentMessages  Message[]           @relation("SentMessages")
  sentDMs       DirectMessage[]     @relation("SentDMs")
  conversations ConversationParticipant[]

  following        Follow[]      @relation("UserFollowing")
  followers        Follow[]      @relation("UserFollowers")
  checkIns         CheckIn[]
  posts            Post[]
  postLikes        PostLike[]
  postComments     PostComment[]
  postTags         PostTag[]     @relation("PostTaggedUser")
  postShares       PostShare[]   @relation("PostShares")
  reviews          EventReview[]
  createdSquads    Squad[]       @relation("CreatedSquads")
  squadMemberships SquadMember[]
  savedEvents      SavedEvent[]
  groupMemberships  GroupMembership[]
  sentGroupMessages GroupMessage[] @relation("SentGroupMessages")
  wallet            Wallet?

  profileViewsReceived ProfileView[] @relation("ProfileViewed")
  profileViewsGiven    ProfileView[] @relation("ProfileViewer")
  nudgesSent           Nudge[]       @relation("NudgeSender")
  nudgesReceived       Nudge[]       @relation("NudgeReceiver")
  goOutSent            GoOutRequest[] @relation("GoOutSender")
  goOutReceived        GoOutRequest[] @relation("GoOutReceiver")
  pubCrawlsCreated     PubCrawl[]     @relation("PubCrawlCreator")
  pubCrawlCheckIns     PubCrawlCheckIn[] @relation("PubCrawlCheckIns")

  referralCards        ReferralCard[]
  socialFeedbackGiven  AnonymousFeedback[] @relation("FeedbackGiven")
  socialFeedbackReceived AnonymousFeedback[] @relation("FeedbackReceived")
  djRequests           DjRequest[]
  djRequestUpvotes     DjRequestUpvote[]
  eventImpressions     EventImpression[]
  eventViews           EventView[]
  phoneVerifications   PhoneVerification[]
  brandEntitlements    BrandEntitlement[]
  nearbyUpdates        NearbyUpdate[]
  swipesGiven    SwipeLike[] @relation("SwipesGiven")
  swipesReceived SwipeLike[] @relation("SwipesReceived")
  moderationLogs ModerationLog[]
  contentReports ContentReport[] @relation("ReportsMade")

  // Spotify Artist profile
  spotifyArtistId       String?
  spotifyArtistData     String?   @db.Text
  spotifyArtistSyncedAt DateTime?
}

model Event {
  id                    String         @id @default(cuid())
  hostId                String
  host                  User           @relation("HostedEvents", fields: [hostId], references: [id])
  name                  String
  type                  EventType
  description           String
  startsAt              DateTime
  endsAt                DateTime?
  lat                   Float
  lng                   Float
  address               String
  neighbourhood         String
  showNeighbourhoodOnly Boolean        @default(false)
  capacity              Int
  price                 Float          @default(0)
  ticketQuantity        Int            @default(0)
  ticketsRemaining      Int            @default(0)
  alcoholPolicy         AlcoholPolicy  @default(NONE)
  ageRestriction        AgeRestriction @default(ALL_AGES)
  dressCode             String?
  whatToBring           String[]
  houseRules            String?
  vibeTags              String[]
  isInviteOnly          Boolean        @default(false)
  inviteToken           String?        @unique
  isPublished           Boolean        @default(false)
  djRequestsEnabled     Boolean        @default(false)
  isCancelled           Boolean        @default(false)
  isFeatured            Boolean        @default(false)
  coverImageUrl         String?
  accentColor           String?
  partySigns            String[]
  lineup                String?
  venueName             String?
  stripeProductId       String?
  stripePriceId         String?
  hostRating            Float?
  eventbriteId          String?        @unique
  eventbriteUrl         String?
  socialSourceUrl       String?
  ticketmasterId        String?        @unique
  skiddleId             String?        @unique
  serpApiId             String?        @unique
  aiEventId             String?        @unique
  externalSource        String?        // "ticketmaster" | "eventbrite" | "skiddle" | "serpapi" | "perplexity"
  venueId               String?
  venue                 Venue?         @relation(fields: [venueId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  guests      EventGuest[]
  tickets     Ticket[]
  messages    Message[]
  moderators  EventModerator[]

  checkIns    CheckIn[]
  posts       Post[]
  reviews     EventReview[]
  savedBy     SavedEvent[]
  djRequests  DjRequest[]
  impressions EventImpression[]
  eventViews  EventView[]

  @@index([hostId, createdAt])
  @@index([isPublished, isCancelled, startsAt])
  @@index([startsAt])
  @@index([venueId])
  @@index([lat, lng])
}

model EventGuest {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RSVPStatus @default(PENDING)
  invitedAt DateTime   @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([eventId, status])
  @@index([userId, status])
}

model EventModerator {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  addedById String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation("EventModeratorUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy   User     @relation("EventModeratorAddedBy", fields: [addedById], references: [id])
  addedAt   DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// ── Discover impressions — event card appeared in a user's feed ───────────────
model EventImpression {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([userId])
}

// ── Event page views — user opened the event detail page ─────────────────────
model EventView {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([userId])
}

model Ticket {
  id              String    @id @default(cuid())
  eventId         String
  userId          String
  event           Event     @relation(fields: [eventId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  qrCode          String    @unique @default(cuid())
  stripePaymentId String?
  stripeSessionId String?
  pricePaid       Float
  platformFee     Float
  scannedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([eventId])
  @@index([userId])
  @@index([eventId, scannedAt])
}

model CelebritySighting {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  celebrity   String
  lat         Float
  lng         Float
  description String?
  photoUrl    String?
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  isVerified  Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  votes SightingVote[]

  @@index([expiresAt])
  @@index([lat, lng])
  @@index([createdAt])
}

model SightingVote {
  id         String            @id @default(cuid())
  sightingId String
  userId     String
  sighting   CelebritySighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  isUpvote   Boolean
  createdAt  DateTime          @default(now())

  @@unique([sightingId, userId])
}

model Subscription {
  id                   String           @id @default(cuid())
  userId               String           @unique
  user                 User             @relation(fields: [userId], references: [id])
  tier                 SubscriptionTier
  stripeSubscriptionId String?          @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

// ─── Venues ───────────────────────────────────────────────────────────────────

model Venue {
  id            String    @id @default(cuid())
  googlePlaceId String?   @unique
  name          String
  address       String
  city          String
  lat           Float
  lng           Float
  type          VenueType
  description   String?   @db.Text
  phone         String?
  website       String?
  photoUrl      String?
  rating        Float?
  openingHours  Json?
  vibeTags      String[]
  isClaimed     Boolean   @default(false)
  claimedById   String?
  claimedBy     User?     @relation("ClaimedVenues", fields: [claimedById], references: [id])
  events        Event[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Spotify "Now Playing" integration
  spotifyConnected    Boolean   @default(false)
  spotifyUserId       String?
  spotifyDisplayName  String?
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  spotifyTokenExpiry  DateTime?
  nowPlayingJson      String?   @db.Text
  nowPlayingAt        DateTime?

  checkIns    CheckIn[]
  posts       Post[]
  postTags    PostTag[] @relation("PostTaggedVenue")
  partnership VenuePartnership?

  @@index([lat, lng])
  @@index([city])
}

// ─── Direct Messages ──────────────────────────────────────────────────────────

model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  lastMessage  String?
  lastAt       DateTime?
  isRequest    Boolean                   @default(false)
  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String       @db.Text
  isSnap         Boolean      @default(false)
  snapViewedAt   DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentDMs", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  eventId   String
  senderId  String
  text      String   @db.Text
  createdAt DateTime @default(now())

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id])

  @@index([eventId, createdAt])
}

// ─── Social ───────────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model CheckIn {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venueId    String?
  venue      Venue?    @relation(fields: [venueId], references: [id], onDelete: SetNull)
  crowdLevel String?   // QUIET | BUSY | RAMMED
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([venueId])
  @@index([createdAt])
}

model Post {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId       String?
  event         Event?         @relation(fields: [eventId], references: [id], onDelete: SetNull)
  venueId       String?
  venue         Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  /// DEPRECATED: Use `media` for new posts. Kept populated with the first
  /// image URL for backwards compat with existing readers.
  imageUrl      String?
  text          String?        @db.Text
  isStory       Boolean        @default(false)
  expiresAt     DateTime?
  likesCount    Int            @default(0)
  commentsCount Int            @default(0)
  viewCount     Int            @default(0)
  sharesCount   Int            @default(0)
  repostsCount  Int            @default(0)
  /// If set, this post is a repost of another post. `user` is still the
  /// reposter — the original author lives on `originalPost.user`. The
  /// text field on a repost holds the reposter's optional caption.
  originalPostId String?
  originalPost   Post?         @relation("PostReposts", fields: [originalPostId], references: [id], onDelete: SetNull)
  reposts        Post[]        @relation("PostReposts")
  createdAt     DateTime       @default(now())

  likes    PostLike[]
  comments PostComment[]
  media    PostMedia[]
  tags     PostTag[]
  shares   PostShare[]

  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
  @@index([isStory, expiresAt])
  @@index([originalPostId])
}

enum PostMediaType {
  IMAGE
  VIDEO
}

/// Ordered media items attached to a post — enables carousels (up to ~10 items)
/// and mixed image/video posts. The Post.imageUrl field is kept populated with
/// media[0].url for backwards compatibility with older readers.
model PostMedia {
  id                 String        @id @default(cuid())
  postId             String
  post               Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  type               PostMediaType @default(IMAGE)
  url                String
  /// Cloudinary public_id — needed to delete from Cloudinary when the post
  /// is deleted. Null if the media came from some other source.
  cloudinaryPublicId String?
  /// Render order in the carousel. Lower = shown first.
  sortOrder          Int           @default(0)
  width              Int?
  height             Int?
  /// Video-only: duration in seconds (nullable for images).
  durationSec        Int?
  /// Video-only: thumbnail/poster URL for before-playback display.
  thumbnailUrl       String?
  createdAt          DateTime      @default(now())

  tags PostTag[]

  @@index([postId, sortOrder])
}

/// Polymorphic tag attached to a post or a specific media item within a post.
/// Exactly one of `taggedUserId` or `taggedVenueId` must be set (enforced at
/// app level — Prisma doesn't express XOR constraints). If `mediaId` is
/// set, the tag is pinned to that carousel item; otherwise it applies to
/// the post as a whole. Optional bounding-box fields (percentages 0-1) let
/// the UI place face/object tags Instagram-style.
model PostTag {
  id            String     @id @default(cuid())
  postId        String
  post          Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaId       String?
  media         PostMedia? @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  taggedUserId  String?
  taggedUser    User?      @relation("PostTaggedUser", fields: [taggedUserId], references: [id], onDelete: Cascade)
  taggedVenueId String?
  taggedVenue   Venue?     @relation("PostTaggedVenue", fields: [taggedVenueId], references: [id], onDelete: Cascade)

  bboxX         Float?
  bboxY         Float?
  bboxW         Float?
  bboxH         Float?

  createdAt     DateTime   @default(now())

  @@index([postId])
  @@index([taggedUserId])
  @@index([taggedVenueId])
}

/// One row per share/repost/copy-link action. Drives the share counter on
/// the post card and the per-post analytics view. `method` is a plain
/// string ("native", "copy", "repost") rather than an enum so we can add
/// new share channels without a migration.
model PostShare {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("PostShares", fields: [userId], references: [id], onDelete: Cascade)
  method    String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model EventReview {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rating      Int
  vibeRating  Int?
  musicRating Int?
  crowdRating Int?
  text        String?  @db.Text
  createdAt   DateTime @default(now())

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
}

model Squad {
  id        String        @id @default(cuid())
  name      String
  emoji     String        @default("🎉")
  createdBy String
  creator   User          @relation("CreatedSquads", fields: [createdBy], references: [id])
  members   SquadMember[]
  createdAt DateTime      @default(now())
}

model SquadMember {
  id        String   @id @default(cuid())
  squadId   String
  userId    String
  role      String   @default("MEMBER") // ADMIN | MEMBER
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([squadId, userId])
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
}

// ─── Group Chats ──────────────────────────────────────────────────────────────

model GroupChat {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  description  String?
  type         GroupType
  emoji        String    @default("🎉")
  coverColor   String    @default("#a855f7")
  isPrivate    Boolean   @default(false)
  password     String?
  isPaid       Boolean   @default(false)
  priceMonthly Float?
  stripePriceId String?
  createdById  String?
  memberCount  Int       @default(0)
  lastMessage  String?
  lastAt       DateTime?
  createdAt    DateTime  @default(now())

  memberships GroupMembership[]
  messages    GroupMessage[]
  subscriptions GroupSubscription[]
  pubCrawls   PubCrawl[]
}

// ─── Pub Crawl ────────────────────────────────────────────────────────────────

model PubCrawl {
  id          String         @id @default(cuid())
  groupId     String
  createdById String
  name        String
  status      String         @default("ACTIVE")
  createdAt   DateTime       @default(now())
  completedAt DateTime?
  group       GroupChat      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("PubCrawlCreator", fields: [createdById], references: [id])
  stops       PubCrawlStop[]

  @@index([groupId])
}

model PubCrawlStop {
  id        String           @id @default(cuid())
  crawlId   String
  name      String
  address   String?
  lat          Float?
  lng          Float?
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  crawl     PubCrawl         @relation(fields: [crawlId], references: [id], onDelete: Cascade)
  checkIns  PubCrawlCheckIn[]

  @@index([crawlId])
}

model PubCrawlCheckIn {
  id        String       @id @default(cuid())
  stopId    String
  userId    String
  createdAt DateTime     @default(now())
  score     Int          @default(1)
  stop      PubCrawlStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  user      User         @relation("PubCrawlCheckIns", fields: [userId], references: [id])

  @@unique([stopId, userId])
  @@index([userId])
}

model GroupSubscription {
  id                   String    @id @default(cuid())
  groupId              String
  userId               String
  group                GroupChat  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

// ─── Referrals ───────────────────────────────────────────────────────────────

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  referredId   String    @unique
  code         String
  earnedAmount Float     @default(0)
  isPaidOut    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([referrerId])
  @@index([code])
}

model GroupMembership {
  id                   String    @id @default(cuid())
  groupId              String
  userId               String
  notificationsEnabled Boolean   @default(true)
  role                 String    @default("MEMBER") // OWNER | MOD | MEMBER
  joinedAt             DateTime  @default(now())
  group                GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model GroupMessage {
  id        String    @id @default(cuid())
  groupId   String
  senderId  String
  text      String?   @db.Text
  imageUrl  String?   @db.Text
  createdAt DateTime  @default(now())
  group     GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User      @relation("SentGroupMessages", fields: [senderId], references: [id])

  @@index([groupId, createdAt])
  @@index([senderId, createdAt])
}

// ─── Push Blast Queue ────────────────────────────────────────────────────────

enum BlastStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

enum WalletTxType {
  TOP_UP
  TICKET_PURCHASE
  DRINK_REWARD
  CARD_ORDER
  VENUE_SPEND
  REFERRAL_CREDIT
  BONUS
  WITHDRAWAL
}

enum WalletTxStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CardDesign {
  CLASSIC_BLACK
  NEON_NIGHTS
  GOLD_VIP
  HOLOGRAPHIC
  CUSTOM
}

enum CardOrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model PushBlast {
  id            String      @id @default(cuid())
  eventId       String
  hostId        String
  tierId        String
  radius        Float
  price         Float
  reach         String
  title         String
  body          String
  status        BlastStatus @default(QUEUED)
  scheduledFor  DateTime    @default(now())
  sentAt        DateTime?
  recipientCount Int?
  stripeSessionId String?
  createdAt     DateTime    @default(now())

  @@index([status, scheduledFor])
  @@index([hostId])
}

// ─── Wallet ──────────────────────────────────────────────────────────────────

model Wallet {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance           Float     @default(0)
  lifetimeSpent     Float     @default(0)
  lifetimeTopUp     Float     @default(0)
  rewardPoints      Int       @default(0)
  freeDrinksEarned  Int       @default(0)
  freeDrinksUsed    Int       @default(0)
  stripeCustomerId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  transactions WalletTransaction[]
  cardOrders   CardOrder[]
}

model WalletTransaction {
  id               String         @id @default(cuid())
  walletId         String
  wallet           Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type             WalletTxType
  amount           Float
  balanceAfter     Float
  description      String
  status           WalletTxStatus @default(COMPLETED)
  stripePaymentId  String?
  stripeSessionId  String?
  eventId          String?
  venueId          String?
  metadata         Json?
  createdAt        DateTime       @default(now())

  @@index([walletId, createdAt])
  @@index([walletId, type])
}

model CardOrder {
  id              String          @id @default(cuid())
  walletId        String
  wallet          Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId          String
  design          CardDesign
  customImageUrl  String?
  nameOnCard      String
  shippingAddress String
  shippingCity    String
  shippingPostcode String
  price           Float
  status          CardOrderStatus @default(PENDING)
  trackingNumber  String?
  stripePaymentId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── Venue Partnerships ──────────────────────────────────────────────────────

model VenuePartnership {
  id              String    @id @default(cuid())
  venueId         String
  venue           Venue     @relation(fields: [venueId], references: [id])
  commissionRate  Float     @default(3)   // % platform takes from venue wallet spends
  isActive        Boolean   @default(true)
  contactEmail    String?
  contactPhone    String?
  agreementUrl    String?
  totalRevenue    Float     @default(0)
  totalOrders     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([venueId])
  drinkMenuItems  DrinkMenuItem[]
}

model DrinkMenuItem {
  id            String           @id @default(cuid())
  partnershipId String
  partnership   VenuePartnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  price         Float
  category      String           @default("drink") // drink, food, combo
  imageUrl      String?
  isAvailable   Boolean          @default(true)
  createdAt     DateTime         @default(now())

  @@index([partnershipId])
}

// ─── Platform Revenue Tracking ───────────────────────────────────────────────

model PlatformRevenue {
  id          String   @id @default(cuid())
  source      String   // ticket_fee, subscription, group_cut, blast, wallet_topup, card_sale, venue_commission, ad_revenue
  amount      Float
  currency    String   @default("gbp")
  referenceId String?  // event/group/user/order ID
  description String?
  createdAt   DateTime @default(now())

  @@index([source, createdAt])
  @@index([createdAt])
}

/// Idempotency ledger for Stripe webhook events. We record the Stripe event
/// ID before processing — if the same event ID arrives again (Stripe retries
/// on network failure), the insert violates the primary key and we bail out
/// without re-crediting the wallet or double-issuing tickets.
model ProcessedStripeEvent {
  id          String   @id  // Stripe event.id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// ─── Social Graph ─────────────────────────────────────────────────────────────

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String
  profileId String
  viewer    User     @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profile   User     @relation("ProfileViewed", fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([viewerId, profileId])
  @@index([profileId, updatedAt])
  @@index([viewerId])
}

model Nudge {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      User     @relation("NudgeSender", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("NudgeReceiver", fields: [toId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([fromId, toId])
  @@index([toId, createdAt])
}

model GoOutRequest {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  message   String?
  status    String   @default("pending") // pending, accepted, declined
  from      User     @relation("GoOutSender", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("GoOutReceiver", fields: [toId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromId, toId])
  @@index([toId, status])
}

// ─── Nearby / Location ───────────────────────────────────────────────────────

model NearbyUpdate {
  id        String   @id @default(cuid())
  userId    String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lat, lng])
}

// ─── Referral Cards ──────────────────────────────────────────────────────────

model ReferralCard {
  id           String   @id @default(cuid())
  userId       String
  code         String   @unique
  displayName  String
  totalUses    Int      @default(0)
  totalEarned  Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  conversions  ReferralConversion[]
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

model ReferralConversion {
  id               String       @id @default(cuid())
  cardId           String
  referredId       String
  revenueAmount    Float
  commissionAmount Float
  isPaidOut        Boolean      @default(false)
  source           String?      // "ticket", "subscription", "group_sub"
  createdAt        DateTime     @default(now())
  card             ReferralCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ─── Social Score & Anonymous Feedback ──────────────────────────────────────

model AnonymousFeedback {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  category    String   // "vibe", "punctuality", "friendliness", "host_quality"
  score       Int      // 1–5
  comment     String?  @db.Text
  isHidden    Boolean  @default(false)
  reportCount Int      @default(0)
  createdAt   DateTime @default(now())
  fromUser    User     @relation("FeedbackGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User     @relation("FeedbackReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId, createdAt]) // rate limit: one per interaction per day enforced at API
  @@index([toUserId])
  @@index([fromUserId])
}

// ─── Phone Verification ──────────────────────────────────────────────────────

model PhoneVerification {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
}

// ─── DJ Song Requests ────────────────────────────────────────────────────────

enum DjRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PLAYED
}

model DjRequest {
  id            String          @id @default(cuid())
  userId        String
  eventId       String?
  venueId       String?
  song          String
  artist        String?
  message       String?         @db.Text
  creditCost    Int             @default(1)
  walletPaid    Boolean         @default(false)  // true = guest paid £1 from wallet
  upvotes       Int             @default(0)
  status        DjRequestStatus @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  event         Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  upvoteEntries DjRequestUpvote[]

  @@index([eventId])
  @@index([userId])
  @@index([venueId])
}

model DjRequestUpvote {
  id        String    @id @default(cuid())
  requestId String
  userId    String
  request   DjRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([requestId, userId])
  @@index([requestId])
  @@index([userId])
}

// ─── Partner Brands (e.g. Saintsinners) ─────────────────────────────────────

enum BrandTier {
  STANDARD
  PREMIUM
  ELITE
}

model PartnerBrand {
  id           String             @id @default(cuid())
  slug         String             @unique
  name         String
  description  String?            @db.Text
  logoUrl      String?
  accentColor  String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  entitlements BrandEntitlement[]
}

model BrandEntitlement {
  id        String       @id @default(cuid())
  brandId   String
  userId    String
  tier      BrandTier    @default(STANDARD)
  note      String?
  grantedAt DateTime     @default(now())
  expiresAt DateTime?
  revokedAt DateTime?
  brand     PartnerBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([brandId, userId])
  @@index([userId])
  @@index([brandId])
}

// ─── Content Moderation ──────────────────────────────────────────────────────

model ModerationLog {
  id          String    @id @default(cuid())
  userId      String
  contentType String    // 'text' | 'image' | 'bio' | 'group_message' | 'post' | 'event'
  contentRef  String?   // groupId/postId/messageId for context
  content     String?   @db.Text
  contentUrl  String?
  flagType    String    // 'SEXUAL' | 'VIOLENCE' | 'ILLEGAL' | 'HATE' | 'SPAM' | 'KEYWORD'
  confidence  Float     @default(1.0)
  action      String    @default("BLOCKED") // 'BLOCKED' | 'FLAGGED' | 'APPROVED' | 'REMOVED'
  autoAction  Boolean   @default(true)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action, createdAt])
  @@index([contentType, createdAt])
}

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  contentType String   // 'post' | 'group_message' | 'group' | 'user' | 'event'
  contentId   String
  reason      String   // 'NUDITY' | 'ILLEGAL' | 'SPAM' | 'HATE' | 'VIOLENCE' | 'OTHER'
  details     String?  @db.Text
  status      String   @default("PENDING") // 'PENDING' | 'REVIEWED' | 'ACTION_TAKEN' | 'DISMISSED'
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  reporter    User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, contentType, contentId])
  @@index([status, createdAt])
  @@index([contentType, contentId])
}

model SwipeLike {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  liked      Boolean
  createdAt  DateTime @default(now())

  fromUser User @relation("SwipesGiven",    fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("SwipesReceived", fields: [toUserId],   references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}
