{
  "expo": {
    "name": "PartyRadar",
    "slug": "partyradar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "partyradar",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.partyradar.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR tickets at events",
        "NSLocationWhenInUseUsageDescription": "Used to show nearby events and celebrity sightings",
        "NSPhotoLibraryUsageDescription": "Used to upload event photos and sighting reports"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0f"
      },
      "package": "com.partyradar.app",
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow PartyRadar to use your location." }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Allow PartyRadar to access your camera for QR scanning." }
      ],
      [
        "@rnmapbox/maps",
        { "RNMapboxMapsDownloadToken": "YOUR_MAPBOX_DOWNLOAD_TOKEN" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
