# ─── packages/api ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/partyradar

# Firebase Admin SDK (from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Places API (for worldwide venue discovery)
GOOGLE_PLACES_API_KEY=

# External event sources — structured APIs
TICKETMASTER_API_KEY=
SKIDDLE_API_KEY=
EVENTBRITE_PRIVATE_TOKEN=

# AI-powered event discovery (fills gaps where above APIs have no coverage)
# SerpAPI: https://serpapi.com — Google Events search, 100 free/month
SERPAPI_KEY=
# Perplexity: https://www.perplexity.ai/api — web AI search, finds Facebook/local events
PERPLEXITY_API_KEY=

# App config
PORT=4000
PLATFORM_FEE_PERCENT=5
CELEBRITY_EXPIRY_HOURS=6
ADMIN_FIREBASE_UIDS=uid1,uid2
# Required for startup auto-seed + hourly reseed cron — set any random string
# and use the same value in Railway env vars (Settings → Variables)
INTERNAL_API_KEY=change_me_to_a_random_secret

# ─── apps/web ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ─── apps/mobile ───────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000/api
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
